# --- Written automatically by `bunx convex dev` ---
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=

# --- Server-side keys (live on the Convex deployment, NOT in the browser) ---
# After filling these in, push them to Convex with: bun run sync-env
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# Optional: only needed if TTS_PROVIDER=openai (cost fallback)
OPENAI_API_KEY=

# TTS provider switch: "elevenlabs" (default) or "openai"
TTS_PROVIDER=elevenlabs

# Used by Convex Auth for redirects (your web app origin)
SITE_URL=http://localhost:5173
